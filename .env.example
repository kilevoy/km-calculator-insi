# FastAPI Drive proxy. Vite reads this only in its Node dev proxy; it is not
# exposed to browser code. In production, the authenticated reverse proxy must
# inject the same Authorization header when forwarding /api requests.
DRIVE_UPLOAD_TOKEN=replace-with-a-long-random-secret
ALLOWED_ORIGINS=https://calculator.example.ru
MAX_UPLOAD_BYTES=20971520
GOOGLE_API_SCRIPT=/opt/google-workspace/google_api.py
DRIVE_ROOT_FOLDER_ID=
DRIVE_ROOT_FOLDER_NAME=КМ-Калькулятор
BUSINESS_TIMEZONE=Asia/Yekaterinburg
HOST=127.0.0.1
PORT=8000
