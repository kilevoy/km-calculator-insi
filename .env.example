# Frontend. For public deployments, prefer authentication at the reverse proxy
# instead of embedding a shared secret in a public JavaScript bundle.
VITE_DRIVE_UPLOAD_TOKEN=

# FastAPI Drive proxy
DRIVE_UPLOAD_TOKEN=replace-with-a-long-random-secret
ALLOWED_ORIGINS=https://calculator.example.ru
MAX_UPLOAD_BYTES=20971520
GOOGLE_API_SCRIPT=/opt/google-workspace/google_api.py
HOST=127.0.0.1
PORT=8000
